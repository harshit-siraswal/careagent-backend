ENVIRONMENT=production
LOG_LEVEL=info
CAREAGENT_AUTH_MODE=firebase
DATABASE_URL=postgresql://careagent_app:<password>@db.<project-ref>.supabase.co:5432/postgres
FIREBASE_PROJECT_ID=studyspace-kiet
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}
CORS_ALLOWED_ORIGINS=https://careagent.example.vercel.app
TRUSTED_HOSTS=careagent-backend.onrender.com,api.careagent.example
ENABLE_API_DOCS=false
MAX_REQUEST_BODY_BYTES=8388608
AGENT_RUNTIME_ADAPTER=mock
AGENT_RUNTIME_PROVIDER=mock
VOICE_PROVIDER_ADAPTER=mock
MAKE_MCP_SERVER_URL=
MAKE_MCP_BEARER_TOKEN=
MAKE_MCP_CALL_TOOL_NAME=
MAKE_MCP_TIMEOUT_SECONDS=20
MAKE_MCP_ALLOW_REAL_CALLS=false
