ENVIRONMENT=production
LOG_LEVEL=info
CAREAGENT_AUTH_MODE=firebase
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
FIREBASE_PROJECT_ID=careagent-pilot
